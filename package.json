{
  "name": "phx-drive",
  "productName": "PHx Drive",
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.4.0",
    "chokidar": "^3.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pharaonx.phxdrive",
    "productName": "PHx Drive",
    "icon": "build/logo.png",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      { "from": "build/logo.png", "to": "logo.png" },
      { "from": "build/logo.ico", "to": "logo.ico" },
      { "from": "build/Drive_Guide.pdf", "to": "Drive_Guide.pdf" }
    ],
    "win": {
      "icon": "build/logo.ico"
    },
    "mac": {
      "icon": "build/logo.png"
    },
    "linux": {
      "icon": "build/logo.png"
    }
  }
}
